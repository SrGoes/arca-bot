# ARCA Bot - Configuração de Ambiente
# 
# Copie este arquivo para .env e configure suas variáveis

# =============================================================================
# DISCORD BOT TOKEN (OBRIGATÓRIO)
# =============================================================================
# Obtenha seu token em: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=seu_token_aqui

# =============================================================================
# CONFIGURAÇÕES OPCIONAIS
# =============================================================================

# Prefixo dos comandos (padrão: !)
# COMMAND_PREFIX=!

# ID do proprietário do bot (seu Discord ID)
# OWNER_ID=123456789012345678

# =============================================================================
# CONFIGURAÇÕES DE DESENVOLVIMENTO
# =============================================================================

# Nível de log (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Ativar modo debug (true/false)
# DEBUG_MODE=false

# =============================================================================
# INSTRUÇÕES
# =============================================================================
# 1. Substitua "seu_token_aqui" pelo token real do seu bot Discord
# 2. Descomente e configure as variáveis opcionais se necessário
# 3. NUNCA compartilhe este arquivo com o token preenchido
# 4. Adicione .env no .gitignore para não enviar o token para o repositório
