# Arquivo de configuração de ambiente
# Copie este arquivo para .env e preencha com seus valores

# Token do bot Discord (obrigatório)
# Obtenha em: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=seu_token_aqui

# ID do canal de log (opcional - o bot procurará pelo nome 'log-cargos')
# LOG_CHANNEL_ID=123456789012345678

# Prefixo dos comandos (opcional - padrão: !)
# COMMAND_PREFIX=!

# Nível de log (opcional - padrão: INFO)
# LOG_LEVEL=INFO
